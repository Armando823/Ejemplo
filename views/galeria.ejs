<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galería</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/estilo.css">
</head>

<body>
    <div class="container mt-5 text-center">
        <h2 class="mb-4">GALERÍA DE IMÁGENES</h2>
        <div class="row justify-content-center g-3">
            <div class="col-4 col-md-3">
                <div class="contenedor-img">
                    <img src="/img/img1.jpg" alt="Imagen 1" class="img-fluid">
                </div>
            </div>
            <div class="col-4 col-md-3">
                <div class="contenedor-img">
                    <img src="/img/img2.jpg" alt="Imagen 2" class="img-fluid">
                </div>
            </div>
            <div class="col-4 col-md-3">
                <div class="contenedor-img">
                    <img src="/img/img3.jpg" alt="Imagen 3" class="img-fluid">
                </div>
            </div>
        </div>
    </div>
    <div id="modalImagen" class="modal-img">
        <span id="cerrarModal">&times;</span>
        <img class="modal-contenido" id="imgModal">
    </div>
    <script src="/js/galeria.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>